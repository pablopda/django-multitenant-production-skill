{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session_start_tenancy.py\"",
            "timeout": 30,
            "statusMessage": "Checking for Django multi-tenancy stack"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/audit_on_edit.py\"",
            "timeout": 30,
            "statusMessage": "Tenant isolation audit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/guard_migrate.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
